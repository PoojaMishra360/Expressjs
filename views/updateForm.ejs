<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <form action="/student-update/<%= student._id %>" method="POST">
        <label for="id"> Id:</label>
        <input type="number" id="id" name="id" value="<%= student.id %>" required><br><br>

        <label for="name">Name:</label>
        <input type="text" id="name" name="name" value="<%= student.name %>" required><br><br>

        <label for="email">Email:</label>
        <input type="email" id="email" name="email" value="<%= student.email %>" required><br><br>
        

        <input type="submit" value="Submit">
</body>
</html>